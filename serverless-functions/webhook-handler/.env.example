# Twilio Configuration
# Your Twilio Auth Token from https://www.twilio.com/console
TWILIO_AUTH_TOKEN=your_auth_token_here

# The full URL of your webhook endpoint (including protocol and path)
# Used by Twilio signature validation to ensure requests come from Twilio
# Example: https://mycompany.com/taskrouter/events
WEBHOOK_URL=https://mycompany.com/taskrouter/events

# Server Configuration
PORT=4000
